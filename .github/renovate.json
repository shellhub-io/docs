{
  "extends": [
    "config:recommended"
  ],
  "customManagers": [
    {
      "fileMatch": [
        "^src/config\\.js$"
      ],
      "matchStrings": [
        "version:\\s*\"(?<currentValue>v\\d+\\.\\d+\\.\\d+)\""
      ],
      "datasourceTemplate": "github-tags",
      "depNameTemplate": "shellhub-io/shellhub",
      "versioningTemplate": "semver",
      "customType": "regex"
    }
  ],
  "packageRules": [
    {
      "enabled": false,
      "matchPackageNames": [
        "*"
      ]
    },
    {
      "enabled": true,
      "matchPackageNames": [
        "shellhub-io/shellhub"
      ]
    }
  ]
}
